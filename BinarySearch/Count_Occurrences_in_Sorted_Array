// Time complexity is  O(log 2 base n) sc = O(1) 
// we have created a new arr[] ans but it is not upto n and O(2) is neglect
import java.util.Scanner;
class Main {
    public static int first(int arr[], int n, int target){
        int low = 0;
        int high = n- 1;
        int first = n;
        while(low <= high){
            int mid = low + (high - low)/2;
            if(arr[mid] >=target){
                first = mid;
                high = mid - 1;
            }
            else{
                low = mid + 1;
            }
        }
        return first;
    }
    
    public static int last(int arr[], int n, int target){
        int low = 0;
        int high = n - 1;
        int last = n;
        while(low <= high){
            int mid = low + (high - low)/2;
            if(arr[mid] > target){
                last = mid;
                high = mid - 1;
            }
            else{
                low = mid + 1;
            }
        }
        return last;
    }
    
    public static int[] firstAndLastOccurence(int arr[], int n, int target){
        int first = first(arr,n,target);
        if(first ==n || arr[first] != target){
            return new int[]{-1, -1};
        }
        int last = last(arr,n,target);
        return new int[]{first, last-1};
    }
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        System.out.print("enter the size of the array : ");
        int n = sc.nextInt();
        System.out.print("enter the elements of the array : ");
        int arr[] = new int[n];
        for(int i=0; i<arr.length; i++){
            arr[i] = sc.nextInt();
        }
         System.out.print("enter the element to be searched : ");
         int target = sc.nextInt();
         int ans[] = firstAndLastOccurence(arr,n, target);
         if(ans[0] == -1){
             System.out.print("the num appeared at 0 times ");
         }
         else{
             int count = ans[1] - ans[0] + 1;
             System.out.print("the element occured this much times : " + count);
         }
         
    }
}
    
